# Database
DB_URL=jdbc:postgresql://localhost:5432/payment_db
DB_USERNAME=payment_app
DB_PASSWORD=dev_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-key-minimum-256-bits

# Jasypt (encryption of Asaas API keys)
JASYPT_PASSWORD=change-this-to-a-secure-random-key

# Asaas
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Master user seed (prod/staging only)
# Set MASTER_SEED_ENABLED=true on the FIRST boot to create the holding admin,
# then set it back to false (or remove) to prevent re-runs.
MASTER_SEED_ENABLED=false
MASTER_SEED_EMAIL=
MASTER_SEED_PASSWORD=
MASTER_SEED_NAME=Master Admin
MASTER_SEED_COMPANY_CNPJ=00000000000100
MASTER_SEED_COMPANY_RAZAO_SOCIAL=Holding Master LTDA
MASTER_SEED_COMPANY_NOME_FANTASIA=Holding Master
